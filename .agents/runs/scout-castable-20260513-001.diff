+# Directories/files that Codex reads from the worktree for protocol behaviour.
+# Uncommitted changes here won't reach the worktree and will silently stale Codex.
+_PROTOCOL_PATHS = (
+    ".agents/schemas/",
+    ".agents/skills/",
+    ".agents/config.toml",
+    ".claude/skills/",
+    "AGENTS.md",
+    "scripts/agents/",
